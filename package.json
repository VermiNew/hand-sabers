{
  "name": "hand-sabers",
  "version": "1.0.0",
  "description": "A Beat Saber-inspired rhythm game you play with your hands through a webcam — no VR headset required.",
  "keywords": [
    "rhythm-game",
    "beat-saber",
    "hand-tracking",
    "webcam",
    "no-vr",
    "three.js",
    "typescript",
    "vite",
    "game"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "node scripts/dev-vite.mjs",
    "dev:client": "vite",
    "dev:server": "npm run server:build && node dist-server/server.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npm run check",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "server": "npm run build && npm run server:build && node dist-server/server.js",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "npm run build && npm run server:build && node dist-server/server.js",
    "client": "vite --host 0.0.0.0",
    "dev:vite": "node scripts/dev-vite.mjs",
    "check": "node scripts/check-js.mjs",
    "smoke": "node scripts/smoke-server.mjs",
    "test": "npm run check && npm run unit && npm run server:build && npm run smoke",
    "verify": "npm run lint && npm run build && npm run typecheck:server && npm run server:build && npm run unit && npm run smoke",
    "postinstall": "node scripts/sync-vendor.mjs",
    "unit": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "express": "^5.2.1",
    "fuse.js": "^7.4.2",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
