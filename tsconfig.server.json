{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "ES2023"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "erasableSyntaxOnly": true,
    "sourceMap": true,
    "outDir": "./dist-server"
  },
  "include": [
    "server.ts",
    "server/**/*.ts",
    "src/core/map-format.ts",
    "src/core/settings.ts",
    "src/core/saber-colors.ts",
    "src/core/translate.ts",
    "src/types/index.ts"
  ]
}
